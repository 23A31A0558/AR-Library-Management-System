<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Categories</title>
    <link href="https://fonts.googleapis.com/css?family=Montserrat:600,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body {
            font-family: 'Montserrat', Arial, sans-serif;
            margin: 0;
            background: linear-gradient(120deg, #e0eafc 0%, #cfdef3 100%);
            min-height: 100vh;
        }
        .container {
            max-width: 800px;
            margin: 40px auto;
            background: #fff;
            border-radius: 22px;
            box-shadow: 0 8px 40px rgba(44,62,80,0.13);
            padding: 48px 36px 36px 36px;
            position: relative;
            overflow: hidden;
        }
        .container::before {
            content: '';
            position: absolute;
            top: -80px;
            right: -80px;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, #6a11cb 0%, #2575fc 100%);
            opacity: 0.12;
            border-radius: 50%;
            z-index: 0;
        }
        h1 {
            color: #2c3e50;
            text-align: center;
            margin-bottom: 32px;
            letter-spacing: 1px;
            font-weight: 700;
            font-size: 2.4rem;
            position: relative;
            z-index: 1;
        }
        .search-bar {
            display: flex;
            justify-content: center;
            margin-bottom: 28px;
            z-index: 2;
            position: relative;
        }
        .search-bar input[type="text"] {
            width: 320px;
            padding: 12px 16px;
            border: 2px solid #2575fc;
            border-radius: 8px 0 0 8px;
            font-size: 1rem;
            outline: none;
            transition: border 0.2s;
        }
        .search-bar button {
            padding: 12px 20px;
            border: none;
            background: linear-gradient(90deg, #6a11cb 0%, #2575fc 100%);
            color: #fff;
            font-size: 1rem;
            border-radius: 0 8px 8px 0;
            cursor: pointer;
            font-weight: 600;
            transition: background 0.2s;
        }
        .search-bar button:hover {
            background: linear-gradient(90deg, #2575fc 0%, #6a11cb 100%);
        }
        .categories {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 22px;
            margin-bottom: 38px;
            position: relative;
            z-index: 1;
        }
        .categories button {
            background: linear-gradient(90deg, #6a11cb 0%, #2575fc 100%);
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 18px 34px;
            font-size: 1.08rem;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 2px 12px rgba(44,62,80,0.10);
            transition: transform 0.13s, box-shadow 0.13s, background 0.2s;
            position: relative;
            overflow: hidden;
        }
        .categories button i {
            margin-right: 10px;
            font-size: 1.2em;
        }
        .categories button:hover, .categories button:focus {
            background: linear-gradient(90deg, #2575fc 0%, #6a11cb 100%);
            transform: translateY(-4px) scale(1.07);
            box-shadow: 0 8px 24px rgba(44,62,80,0.16);
            outline: none;
        }
        .books {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            justify-content: center;
            margin-bottom: 20px;
            animation: fadeIn 0.6s;
            position: relative;
            z-index: 1;
        }
        .book-card {
            background: #f8faff;
            border-radius: 14px;
            box-shadow: 0 2px 12px rgba(44,62,80,0.07);
            padding: 18px 20px;
            min-width: 180px;
            max-width: 220px;
            text-align: center;
            transition: transform 0.13s, box-shadow 0.13s;
            cursor: pointer;
            border: 2px solid transparent;
            position: relative;
        }
        .book-card:hover, .book-card:focus {
            transform: scale(1.06) translateY(-3px);
            box-shadow: 0 8px 24px rgba(44,62,80,0.13);
            border: 2px solid #2575fc;
            outline: none;
        }
        .book-card i {
            font-size: 2.1em;
            color: #6a11cb;
            margin-bottom: 10px;
        }
        .book-title {
            font-size: 1.08em;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 6px;
        }
        .book-img {
            display: none;
            margin: 0 auto;
            margin-top: 34px;
            max-width: 340px;
            border-radius: 16px;
            box-shadow: 0 6px 32px rgba(44,62,80,0.13);
            animation: fadeInImg 0.7s;
            border: 4px solid #2575fc;
            background: #fff;
            position: relative;
            z-index: 2;
        }
        .img-label {
            text-align: center;
            font-size: 1.1em;
            color: #2575fc;
            font-weight: 600;
            margin-top: 18px;
            letter-spacing: 0.5px;
            display: none;
            position: relative;
            z-index: 2;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px);}
            to { opacity: 1; transform: translateY(0);}
        }
        @keyframes fadeInImg {
            from { opacity: 0; transform: scale(0.95);}
            to { opacity: 1; transform: scale(1);}
        }
        .shape {
            position: absolute;
            border-radius: 50%;
            opacity: 0.13;
            z-index: 0;
        }
        .shape1 {
            width: 120px; height: 120px; background: #6a11cb; top: 10px; left: -60px;
        }
        .shape2 {
            width: 80px; height: 80px; background: #2575fc; bottom: 10px; right: -40px;
        }
        @media (max-width: 700px) {
            .container { padding: 18px 6px; }
            .search-bar input[type="text"] { width: 98vw; }
            .categories, .books { gap: 10px; }
            .categories button, .book-card { padding: 12px 10px; font-size: 0.98rem; }
            .book-card { min-width: 120px; max-width: 100%; }
            .book-img { max-width: 98vw; }
        }
    </style>
    <script>
        // Define books for each category, with subcategories only for Programming > Java
        const booksByCategory = {
            "Programming": [
                {
                    name: "Java",
                    icon: "fa-brands fa-java",
                    subcategory: [
                        { name: "Big Java", img: "newbigjava.jpg" },
                        { name: "Java Server Pages", img: "javaserver.jpg" },
                        { name: "Programming With Java A Primer", img: "javaprimer.jpg" },
                        { name: "Java One Step Ahead By Oxford", img: "oxford.jpg" },
                        { name: "Java Seventh Edition ", img: "javaseven.jpg" }
                    ]
                },
                { name: "Python Programming", img: "python.jpg", icon: "fa-brands fa-python" },
                { name: "JavaScript for Beginners", img: "js_beginners.jpg", icon: "fa-brands fa-js" },
                { name: "C# Fundamentals", img: "csharp_book.jpg", icon: "fa-solid fa-caret-right" },
                { name: "C++ Basics", img: "cpp_book.jpg", icon: "fa-solid fa-caret-right" }
            ],
            "Ethics and Human values": [
                { name: "Professional Ethics And Human Values", img: "proethics.jpg" },
                { name: "Indian Cultural Values And Professional Ethics", img: "indian.jpg" },
                { name: "Ethics In Engineering", img: "ethics.jpg" },
                { name: "Professional Ethics And Morals", img: "morals.jpg" }
            ],
            "Problem-solving": [
                { name: "Advanced Data Structures", img: "ads.jpg", icon: "fa-solid fa-puzzle-piece" },
                { name: "Logical Thinking", img: "logical_thinking.jpg", icon: "fa-solid fa-brain" }
            ],
            "Database Systems": [
                { name: "SQL Fundamentals", img: "sql_book.jpg", icon: "fa-solid fa-database" },
                { name: "Database Design", img: "db_design.jpg", icon: "fa-solid fa-sitemap" }
            ],
            "Web Technologies": [
                { name: "HTML & CSS", img: "html_css.jpg", icon: "fa-brands fa-html5" },
                { name: "JavaScript Guide", img: "js_guide.jpg", icon: "fa-brands fa-js" }
            ],
            "Data Science": [
                { name: "Data Science Intro", img: "ds_intro.jpg", icon: "fa-solid fa-chart-line" },
                { name: "Machine Learning", img: "ml_book.jpg", icon: "fa-solid fa-robot" }
            ]
        };

        let currentCategory = null;
        let currentSubcategory = null;

        function showBooks(category) {
            currentCategory = category;
            currentSubcategory = null;
            document.getElementById('search-input').value = '';
            renderBooks(booksByCategory[category]);
        }

        function renderBooks(books) {
            const booksDiv = document.getElementById('books');
            const bookImg = document.getElementById('book-img');
            const imgLabel = document.getElementById('img-label');
            booksDiv.innerHTML = '';
            if (books) {
                books.forEach(book => {
                    // Only Programming > Java has subcategories
                    if (currentCategory === "Programming" && book.subcategory) {
                        const card = document.createElement('div');
                        card.className = 'book-card';
                        card.tabIndex = 0;
                        card.onclick = function() {
                            currentSubcategory = book.name;
                            renderSubCategory(book.subcategory, book.name);
                        };
                        card.onkeydown = function(e) {
                            if (e.key === 'Enter' || e.key === ' ') card.onclick();
                        };
                        const icon = document.createElement('i');
                        icon.className = book.icon;
                        card.appendChild(icon);
                        const title = document.createElement('div');
                        title.className = 'book-title';
                        title.textContent = book.name + " ▼";
                        card.appendChild(title);
                        booksDiv.appendChild(card);
                    } else {
                        const card = document.createElement('div');
                        card.className = 'book-card';
                        card.tabIndex = 0;
                        card.onclick = function() {
                            bookImg.src = book.img;
                            bookImg.style.display = 'block';
                            imgLabel.textContent = book.name;
                            imgLabel.style.display = 'block';
                            bookImg.classList.remove('fadeInImg');
                            void bookImg.offsetWidth;
                            bookImg.classList.add('fadeInImg');
                        };
                        card.onkeydown = function(e) {
                            if (e.key === 'Enter' || e.key === ' ') card.onclick();
                        };
                        const icon = document.createElement('i');
                        icon.className = book.icon;
                        card.appendChild(icon);
                        const title = document.createElement('div');
                        title.className = 'book-title';
                        title.textContent = book.name;
                        card.appendChild(title);
                        booksDiv.appendChild(card);
                    }
                });
            }
            bookImg.style.display = 'none';
            imgLabel.style.display = 'none';
            booksDiv.style.display = 'flex';
        }

        // Show subcategory books for Java (no icons for subcategories)
        function renderSubCategory(subBooks, parentName) {
            const booksDiv = document.getElementById('books');
            const bookImg = document.getElementById('book-img');
            const imgLabel = document.getElementById('img-label');
            booksDiv.innerHTML = '';
            subBooks.forEach(book => {
                const card = document.createElement('div');
                card.className = 'book-card';
                card.tabIndex = 0;
                card.onclick = function() {
                    bookImg.src = book.img;
                    bookImg.style.display = 'block';
                    imgLabel.textContent = parentName + " - " + book.name;
                    imgLabel.style.display = 'block';
                    bookImg.classList.remove('fadeInImg');
                    void bookImg.offsetWidth;
                    bookImg.classList.add('fadeInImg');
                };
                card.onkeydown = function(e) {
                    if (e.key === 'Enter' || e.key === ' ') card.onclick();
                };
                // No icon for subcategories
                const title = document.createElement('div');
                title.className = 'book-title';
                title.textContent = book.name;
                card.appendChild(title);
                booksDiv.appendChild(card);
            });
            // Add a back button to return to Programming books
            const backBtn = document.createElement('button');
            backBtn.textContent = "← Back";
            backBtn.style.margin = "20px auto 0";
            backBtn.style.display = "block";
            backBtn.style.background = "#2575fc";
            backBtn.style.color = "#fff";
            backBtn.style.border = "none";
            backBtn.style.borderRadius = "8px";
            backBtn.style.padding = "10px 24px";
            backBtn.style.fontWeight = "600";
            backBtn.style.cursor = "pointer";
            backBtn.onclick = function() {
                renderBooks(booksByCategory['Programming']);
            };
            booksDiv.appendChild(backBtn);

            bookImg.style.display = 'none';
            imgLabel.style.display = 'none';
            booksDiv.style.display = 'flex';
            booksDiv.style.flexDirection = 'row';
            booksDiv.style.flexWrap = 'wrap';
            booksDiv.style.justifyContent = 'center';
        }

        // Search functionality
        function searchBooks() {
            const query = document.getElementById('search-input').value.trim().toLowerCase();
            if (!currentCategory) return;
            let books = booksByCategory[currentCategory];
            let filtered = [];
            if (currentCategory === "Programming") {
                books.forEach(book => {
                    if (book.subcategory) {
                        // Search in subcategory
                        const subFiltered = book.subcategory.filter(sub =>
                            sub.name.toLowerCase().includes(query)
                        );
                        if (book.name.toLowerCase().includes(query)) {
                            filtered.push(book);
                        }
                        if (subFiltered.length > 0) {
                            filtered.push({
                                name: book.name,
                                subcategory: subFiltered,
                                icon: book.icon
                            });
                        }
                    } else if (book.name.toLowerCase().includes(query)) {
                        filtered.push(book);
                    }
                });
            } else {
                filtered = books.filter(book =>
                    book.name.toLowerCase().includes(query)
                );
            }
            renderBooks(filtered);
        }
    </script>
</head>
<body>
    <div class="container">
        <span class="shape shape1"></span>
        <span class="shape shape2"></span>
        <h1>Book Categories</h1>
        <div class="search-bar">
            <input type="text" id="search-input" placeholder="Search for a book..." oninput="searchBooks()">
            <button onclick="searchBooks()"><i class="fa fa-search"></i></button>
        </div>
        <div class="categories">
            <button onclick="showBooks('Programming')"><i class="fa-solid fa-code"></i>Programming</button>
            <button onclick="showBooks('Ethics and Human values')"><i class="fa-solid fa-scale-balanced"></i>Ethics & Human Values</button>
            <button onclick="showBooks('Problem-solving')"><i class="fa-solid fa-puzzle-piece"></i>Problem Solving</button>
            <button onclick="showBooks('Database Systems')"><i class="fa-solid fa-database"></i>Database</button>
            <button onclick="showBooks('Web Technologies')"><i class="fa-solid fa-globe"></i>Web Technologies</button>
            <button onclick="showBooks('Data Science')"><i class="fa-solid fa-chart-bar"></i>Data Science</button>   
        </div>
        <div id="books" class="books" style="display:none;">
            <!-- Books will be shown here -->
        </div>
        <div class="img-label" id="img-label"></div>
        <img id="book-img" class="book-img" src="" alt="Book Photo">
        <!-- Place your images (e.g., core_java.jpg, advanced_java.jpg, java_beginners.jpg, etc.) in the same folder as this HTML file -->
    </div>
</body>